# Supabase → Project Settings → API
# Bu dosyayı kopyalayıp .env.local yapın; Vercel’de aynı isimlerle Environment Variables ekleyin.
# URL mutlaka protokol içermeli (https://...).
# Vercel’de yalnızca SUPABASE_URL + SUPABASE_ANON_KEY tanımlıysa (API için), Vite build bunları
# otomatik olarak istemciye VITE_* olarak da eşler — ayrıca VITE_* yazmanız gerekmez.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Sunucu API (/api/*, Vercel): tablolara tam erişim — istemciye ASLA koymayın
SUPABASE_SERVICE_ROLE_KEY=
# Opsiyonel: canlı ders paket birimi (süre → birim) — JSON dizi. Boş bırakılırsa 1–45→1, 46–80→2, 81–120→3, sonrası +40 dk/+1
# LESSON_DURATION_UNIT_RULES=[{"maxMinutes":45,"units":1},{"maxMinutes":80,"units":2},{"maxMinutes":999999,"units":10}]
# API: boş bırakın = Vercel’de /api aynı origin. Tüm API’yi kendi sunucunuzda barındırıyorsanız:
# VITE_API_BASE_URL=https://api.sizin-domain.com
#
# WhatsApp gateway (ayrı sunucu, örn. :4010). Kopya değerler: repo kökü SUNUCU-27-102-134-199-ORTAM.md
# Gerçek URL (http://IP:4010). Değişken adını veya boşluklu metin yazmayın — Vercel’de aynısı.
VITE_WHATSAPP_GATEWAY_URL=http://localhost:4010
VITE_WHATSAPP_GATEWAY_KEY=
# HTTPS siteden HTTP gateway: Vercel sunucusu proxy — kök dizinde wa-gateway kullanır (VITE_* değil).
# WHATSAPP_GATEWAY_UPSTREAM=http://27.x.x.x:4010

# ── Meta WhatsApp Cloud API — Vercel sunucu ortamı (VITE_* değil)
# META_WHATSAPP_TOKEN=
# META_PHONE_NUMBER_ID=
# META_WABA_ID=
# META_GRAPH_API_VERSION=v21.0
#
# Koç otomatik WhatsApp şablonu (cron `coach-whatsapp-auto`): tek gövde değişkeni — tam metin
# META_COACH_AUTOMATION_TEMPLATE_NAME=
# META_COACH_AUTOMATION_TEMPLATE_LANGUAGE=tr
#
# Günlük takip WhatsApp hatırlatması (cron — sql: 2026-tracking-reminder-log.sql):
# TRACKING_REMINDER_ENABLED=true
# TRACKING_REMINDER_HOUR_TR=22
# TRACKING_REMINDER_CRON_SECRET=...   # veya MEETING_CRON_SECRET
#
# Koç otomatik zamanlayıcı (SQL: sql/2026-coach-whatsapp-auto-schedule.sql):
# Cron: GET|POST /api/cron/coach-whatsapp-auto  (vercel.json’da varsayılan: her 15 dk)
# COACH_WHATSAPP_CRON_SECRET=...   # opsiyonel; yoksa MEETING_CRON_SECRET / CRON_SECRET
# COACH_WHATSAPP_AUTO_ENABLED=true   # kapatmak için false
