# Supabase → Project Settings → API
# Bu dosyayı kopyalayıp .env.local yapın; Vercel’de aynı isimlerle Environment Variables ekleyin.
# URL mutlaka protokol içermeli (https://...).
# Vercel’de yalnızca SUPABASE_URL + SUPABASE_ANON_KEY tanımlıysa (API için), Vite build bunları
# otomatik olarak istemciye VITE_* olarak da eşler — ayrıca VITE_* yazmanız gerekmez.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Sunucu API (/api/*, Vercel): tablolara tam erişim — istemciye ASLA koymayın
SUPABASE_SERVICE_ROLE_KEY=
# Opsiyonel: canlı ders paket birimi (süre → birim) — JSON dizi. Boş bırakılırsa 1–45→1, 46–80→2, 81–120→3, sonrası +40 dk/+1
# LESSON_DURATION_UNIT_RULES=[{"maxMinutes":45,"units":1},{"maxMinutes":80,"units":2},{"maxMinutes":999999,"units":10}]
# API: boş bırakın = Vercel’de /api aynı origin. Tüm API’yi kendi sunucuunuzda barındırıyorsanız:
# VITE_API_BASE_URL=https://api.sizin-domain.com
# Capacitor mobil build için zorunlu (.env.mobile): VITE_API_BASE_URL=https://www.dersonlinevipkocluk.com
# (Next.js şablonundaki NEXT_PUBLIC_API_URL yerine bu projede VITE_API_BASE_URL kullanılır;
#  yerel geliştirme için boş bırakmanız yeterli — istekler http://localhost:5173/api üzerinden proxy edilir.)
#
# OpenAI — AI Koç sohbeti (/api/ai-chat). Önerilen: yalnızca sunucu ortamı.
# Ayarlar sayfasında tarayıcı BYOK anahtarı da kullanılabilir; sunucu anahtarı varsa o önceliklidir.
# ── Edesis (sınav sonuçları — API key, webhook yok)
# Edesis External API v1 (Vercel / sunucu)
# EDESIS_API_KEY=
# EDESIS_API_BASE_URL=https://onlinevipdershane.api.edesis.com
# EDESIS_AUTH_MODE=x-api-key

# ── E-posta (şifre sıfırlama) — Resend önerilir (domain doğrulama gerekir)
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@dersonlinevipkocluk.com
# EMAIL_FROM_NAME=Smart VIP Koçluk
# APP_PUBLIC_URL=https://www.dersonlinevipkocluk.com
# Alternatif: SENDGRID_API_KEY=SG....

# OPENAI_API_KEY=
#
# WhatsApp gateway (ayrı sunucu, örn. :4010). Kopya değerler: repo kökü SUNUCU-27-102-134-199-ORTAM.md
# Gerçek URL (http://IP:4010). Değişken adını veya boşluklu metin yazmayın — Vercel’de aynısı.
VITE_WHATSAPP_GATEWAY_URL=http://localhost:4010
VITE_WHATSAPP_GATEWAY_KEY=
# HTTPS siteden HTTP gateway: Vercel sunucusu proxy — kök dizinde wa-gateway kullanır (VITE_* değil).
# WHATSAPP_GATEWAY_UPSTREAM=http://27.x.x.x:4010
# Kitap siparişleri: QR bağlı kullanıcı UUID (Koç WhatsApp ayarlarındaki oturum id)
# BOOK_ORDER_GATEWAY_SESSION_ID=
# Kitap siparişleri: önce gateway (QR), olmazsa Meta şablonu (varsayılan)
# BOOK_ORDER_WHATSAPP_CHANNEL=gateway
# BOOK_ORDER_WHATSAPP_FALLBACK_META=0  # yalnızca gateway, Meta yedek kapalı
#
# Günlük rapor hatırlatması (cron daily-report-reminders) — varsayılan gateway 22:00 İstanbul
# WHATSAPP_AUTOMATION_CHANNEL=gateway
# WHATSAPP_AUTOMATION_GATEWAY_SESSION_ID=  # boşsa BOOK_ORDER_GATEWAY_SESSION_ID
# REPORT_REMINDER_IST_HOUR=22
# Meta'ya dönmek için: WHATSAPP_AUTOMATION_CHANNEL=meta
# WHATSAPP_GATEWAY_UPSTREAM=

# ── Meta WhatsApp Cloud API — Vercel sunucu ortamı (VITE_* değil)
# META_WHATSAPP_TOKEN=
# META_PHONE_NUMBER_ID=
# META_WABA_ID=
# META_GRAPH_API_VERSION=v21.0
#
# ── BigBlueButton (BBB) API — sunucu ortamı (opsiyonel)
# Meetings ekranında link girmeden otomatik BBB odası üretmek için:
# BBB_API_ENDPOINT=https://sizin-bbb-domain.com/bigbluebutton/api
# BBB_API_SECRET=...
# BBB_MEETING_DURATION_MINUTES=120
# Kayıt: varsayılan öğretmen manuel başlatır (otomatik kayıt kapalı)
# BBB_RECORD=true
# BBB_AUTO_START_RECORDING=false
# BBB_ALLOW_START_STOP_RECORDING=true
# BBB_RECORD_FULL_DURATION_MEDIA=true
#
# Koç otomatik WhatsApp şablonu (cron `coach-whatsapp-auto`): tek gövde değişkeni — tam metin
# META_COACH_AUTOMATION_TEMPLATE_NAME=
# META_COACH_AUTOMATION_TEMPLATE_LANGUAGE=tr
#
# Günlük takip WhatsApp hatırlatması (cron — sql: 2026-tracking-reminder-log.sql):
# TRACKING_REMINDER_ENABLED=true
# TRACKING_REMINDER_HOUR_TR=22
# TRACKING_REMINDER_CRON_SECRET=...   # veya MEETING_CRON_SECRET
#
# Koç otomatik zamanlayıcı (SQL: sql/2026-coach-whatsapp-auto-schedule.sql):
# Cron: GET|POST /api/cron/coach-whatsapp-auto  (vercel.json’da varsayılan: her 15 dk)
# COACH_WHATSAPP_CRON_SECRET=...   # opsiyonel; yoksa MEETING_CRON_SECRET / CRON_SECRET
# COACH_WHATSAPP_AUTO_ENABLED=true   # kapatmak için false
