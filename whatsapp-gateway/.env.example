PORT=4010
WHATSAPP_DATA_DIR=./data
LOG_LEVEL=info

# Required for auth hardening
APP_JWT_SECRET=replace-with-same-secret-as-main-api

# Optional but recommended: second gate for service-to-service access
GATEWAY_API_KEY=replace-with-long-random-string

# Admin may manage this shared session id without JWT sub match (kitap siparişi QR)
# BOOK_ORDER_GATEWAY_SESSION_ID=uuid-of-user-who-owns-whatsapp-line

# Comma separated origins — panel adresiniz (Vercel) zorunlu
CORS_ALLOWED_ORIGINS=https://www.dersonlinevipkocluk.com,https://smart-kocluk-ceyhu.vercel.app,http://localhost:5173

# Send/reconnect stabilization
WA_CONNECTING_TIMEOUT_MS=75000
WA_RECONNECT_TIMEOUT_MS=180000
WA_SESSION_WATCHDOG_MS=45000
WA_MAX_RECONNECT_ATTEMPTS=24
WA_RESTORE_BLOCK_MS=86400000
SEND_MESSAGE_TIMEOUT_MS=35000
WA_SEND_READY_DELAY_MS=1200
WA_SEND_WAIT_READY_MS=9000
WA_SEND_WAIT_POLL_MS=200
# 1 = libsignal "Closing session: SessionEntry" stdout spam suppress
SILENCE_SIGNAL_SESSION_LOGS=1
