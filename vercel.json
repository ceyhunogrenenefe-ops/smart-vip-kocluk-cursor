{

  "$schema": "https://openapi.vercel.sh/vercel.json",

  "functions": {

    "api/wa-gateway.js": {

      "maxDuration": 120

    }

  },

  "installCommand": "npm install && cd student-coaching-system && npm install",

  "buildCommand": "cd student-coaching-system && npm run build",

  "outputDirectory": "student-coaching-system/dist",

  "framework": null,

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],

  "crons": [
    {
      "path": "/api/cron/meeting-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/coach-whatsapp-auto",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/teacher-lessons",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/lesson-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/class-lesson-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/class-sessions",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/class-homework-notify",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/class-absent-notify-retry",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/daily-report-reminders",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/cron/study-evening-reminder",
      "schedule": "0 19 * * *"
    }
  ],

  "rewrites": [

    {

      "source": "/api/whatsapp-gateway/(.*)",

      "destination": "/api/wa-gateway?tail=$1"

    },

    {

      "source": "/api/google/(.*)",

      "destination": "/api/deep-api?path=google/$1"

    },

    {

      "source": "/api/cron/(.*)",

      "destination": "/api/deep-api?path=cron/$1"

    },

    {

      "source": "/api/meta/(.*)",

      "destination": "/api/deep-api?path=meta/$1"

    },

    {

      "source": "/api/whatsapp/(.*)",

      "destination": "/api/deep-api?path=whatsapp/$1"

    },

    {

      "source": "/",

      "destination": "/index.html"

    },

    {

      "source": "/((?!api/).+)",

      "destination": "/index.html"

    }

  ]

}


