{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/auth-login.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/wa-gateway.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/[[...segments]].js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "installCommand": "npm install && cd student-coaching-system && npm install",
  "buildCommand": "cd student-coaching-system && npm run build",
  "outputDirectory": "student-coaching-system/dist",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/meeting-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/coach-whatsapp-auto",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/teacher-lessons",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/class-sessions",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/class-homework-notify",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/edu-homework-media-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/edu-homework-reminders",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/class-absent-notify-retry",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/daily-report-reminders",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/institution-events",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/book-orders",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/veli-kayit-admin-notify-retry",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/veli-sign-ready-notify-retry",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/edesis-sync",
      "schedule": "0 6,18 * * *"
    },
    {
      "path": "/api/cron/taksit-reminders",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/solution-appointment-reminders",
      "schedule": "*/5 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "dersonlinevipkocluk.com" }],
      "destination": "https://www.dersonlinevipkocluk.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/whatsapp-gateway/(.*)",
      "destination": "/api/wa-gateway?tail=$1"
    },
    {
      "source": "/api/google/(.*)",
      "destination": "/api/deep-api?path=google/$1"
    },
    {
      "source": "/api/meta/(.*)",
      "destination": "/api/deep-api?path=meta/$1"
    },
    {
      "source": "/api/whatsapp/(.*)",
      "destination": "/api/deep-api?path=whatsapp/$1"
    },
    {
      "source": "/api/question-help/webhook",
      "destination": "/api/deep-api?path=question-help/webhook"
    },
    {
      "source": "/veli-imza/:token",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i)(^WhatsApp/|.*(facebookexternalhit|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot).*)"
        }
      ],
      "destination": "/api/veli-imza-preview?signing_token=:token"
    },
    {
      "source": "/d/:code",
      "has": [
        {
          "type": "header",
          "key": "User-Agent",
          "value": "(?i)(^WhatsApp/|.*(facebookexternalhit|Twitterbot|LinkedInBot|Slackbot|TelegramBot|Discordbot).*)"
        }
      ],
      "destination": "/api/guest-join-preview?code=:code"
    },
    {
      "source": "/((?!api/|assets/|ders-program-planner/).*)",
      "destination": "/index.html"
    }
  ]
}
